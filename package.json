{
  "private": true,
  "name": "magic-agent",
  "description": "Magic Agent monorepo - Mobile and web client for Claude Code and Codex",
  "packageManager": "yarn@4.14.1",
  "workspaces": [
    "packages/schema/errors",
    "packages/schema/protocol",
    "dev/lint-rules",
    "apps/cli",
    "apps/server/docker",
    "apps/server/workers",
    "apps/web/vue",
    "apps/admin/api",
    "apps/admin/web"
  ],
  "scripts": {
    "preinstall": "node -e \"const p=require('path');if(process.cwd()!==p.dirname(p.resolve('./package.json'))){console.error('\\n❌ Run yarn install from the monorepo root:\\n   cd '+p.dirname(p.resolve('./package.json'))+'\\n');process.exit(1)}\"",
    "postinstall": "yarn workspace @magic-agent/errors build && yarn workspace @magic-agent/protocol build",
    "build": "turbo run build",
    "build:errors": "yarn workspace @magic-agent/errors build",
    "build:protocol": "yarn workspace @magic-agent/protocol build",
    "typecheck": "turbo run typecheck",
    "typecheck:errors": "yarn workspace @magic-agent/errors typecheck",
    "typecheck:protocol": "yarn workspace @magic-agent/protocol typecheck",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "format:root": "vp fmt .",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "dev": "turbo run dev",
    "clean": "turbo run clean",
    "schema:extract": "yarn workspace @magic-agent/protocol schema:extract",
    "schema:compare": "tsx scripts/compare-schemas.ts",
    "ncu:all": "find . -name package.json -not -path '*/node_modules/*' -execdir ncu -u \\;",
    "deploy:stack:pro": "turbo run deploy:prod --filter=happy-server-workers --filter=happy",
    "deploy:stack:dev": "turbo run deploy:dev --filter=happy-server-workers --filter=happy"
  },
  "overrides": {
    "minimatch": "^10.2.5"
  },
  "resolutions": {
    "minimatch": "^10.2.5"
  },
  "devDependencies": {
    "tsx": "^4.22.2",
    "turbo": "^2.9.14",
    "vite-plus": "^0.1.21",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
