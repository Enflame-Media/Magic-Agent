{
  "name": "happy",
  "main": "index.ts",
  "version": "1.0.0",
  "scripts": {
    "preinstall": "node -e \"if(!process.env.INIT_CWD?.endsWith('/magicagent')){console.error('❌ Run yarn install from monorepo root');process.exit(1)}\"",
    "help": "echo '\nHappy App - Available Scripts\n==============================\n\nDevelopment:\n  start              Start Expo dev server\n  start:local-server Start with local server and debug flags\n  web                Start web version\n\nMobile:\n  android            Run on Android emulator\n  ios                Run on iOS simulator\n  ios:connected-device Run on connected iOS device\n  prebuild           Generate native iOS/Android directories\n\nBuild & Test:\n  typecheck          Type-check TypeScript\n  test               Run tests with Vitest\n\nProduction:\n  submit             Submit to App Store via EAS\n  ota                Deploy OTA update to preview branch\n  ota:production     Deploy OTA update to production\n\nUtilities:\n  generate-theme     Generate theme configuration\n'",
    "start": "npx expo start",
    "start:local-server": "EXPO_PUBLIC_DANGEROUSLY_LOG_TO_SERVER_FOR_AI_AUTO_DEBUGGING=1 EXPO_PUBLIC_DEBUG=1 EXPO_PUBLIC_HAPPY_SERVER_URL=http://localhost:3005 npx expo start -c",
    "android": "npx expo run:android",
    "ios": "npx expo run:ios",
    "ios:connected-device": "yarn ios -d $(xcrun devicectl list devices | grep -E \"available \\(paired\\)\" | head -1 | awk '{print $1}')",
    "submit": "eas submit --platform ios",
    "web": "npx expo start --web",
    "test": "vp test",
    "prebuild": "rm -rf android ios && npx expo prebuild",
    "ota": "APP_ENV=preview NODE_ENV=preview tsx sources/scripts/parseChangelog.ts && yarn typecheck && eas update --branch preview",
    "ota:production": "npx eas-cli@latest workflow:run ota.yaml",
    "typecheck": "tsc --noEmit",
    "postinstall": "patch-package",
    "generate-theme": "tsx sources/theme.gen.ts",
    "lint": "oxlint sources --config oxlint.json",
    "lint:fix": "oxlint sources --config oxlint.json --fix",
    "lint:github-casing": "node ../scripts/lint-github-casing.mjs sources",
    "lint:protocol-helpers": "node ../scripts/lint-protocol-helpers.mjs sources",
    "lint:env": "bash -c 'RESULT=$(grep -rn --include=\"*.ts\" --include=\"*.tsx\" \"process.env.\" sources/ | grep -v EXPO_PUBLIC_ | grep -v __testdata__ || true); if [ -n \"$RESULT\" ]; then echo \"❌ Found process.env usages without EXPO_PUBLIC_ prefix:\"; echo \"$RESULT\"; exit 1; else echo \"✓ All process.env usages use EXPO_PUBLIC_ prefix\"; fi'",
    "format": "oxfmt sources/",
    "format:check": "oxfmt --check sources/",
    "clean": "rm -rf dist .expo",
    "knip": "knip",
    "analyze:bundle": "tsx sources/scripts/analyzeBundleSize.ts",
    "analyze:bundle:ci": "tsx sources/scripts/analyzeBundleSize.ts --format github --fail-on-regression",
    "extract-cert-pins": "tsx sources/scripts/extractCertPins.ts",
    "build:web": "NODE_ENV=production APP_ENV=production EXPO_PUBLIC_HAPPY_SERVER_URL=https://happy-api.enflamemedia.com npx expo export --platform web --output-dir dist",
    "build:web:preview": "NODE_ENV=production APP_ENV=preview EXPO_PUBLIC_HAPPY_SERVER_URL=https://happy-api-dev.enflamemedia.com npx expo export --platform web --output-dir dist",
    "build:web:dev": "NODE_ENV=development APP_ENV=development EXPO_PUBLIC_HAPPY_SERVER_URL=https://happy-api-dev.enflamemedia.com npx expo export --platform web --output-dir dist",
    "deploy:workers:pro": "yarn build:web && wrangler deploy --env production",
    "deploy:workers:dev": "yarn build:web:dev && wrangler deploy --env development"
  },
  "jest": {
    "preset": "jest-expo"
  },
