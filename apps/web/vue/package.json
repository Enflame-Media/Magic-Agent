{
  "name": "happy-vue",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Happy Vue.js web application for Claude Code remote control",
  "scripts": {
    "preinstall": "node -e \"if(!process.env.INIT_CWD?.endsWith('/happy')){console.error('❌ Run yarn install from monorepo root');process.exit(1)}\"",
    "dev": "vp dev",
    "build": "vp check && vp build",
    "preview": "vp preview",
    "typecheck": "npx vue-tsc --noEmit",
    "test": "vp test",
    "test:run": "vp test run",
    "test:watch": "vp test watch",
    "test:coverage": "vp test --coverage",
    "test:unit": "vp test run --coverage --reporter=verbose",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:e2e:visual": "percy exec -- playwright test e2e/visual.spec.ts",
    "test:e2e:visual:local": "playwright test e2e/visual.spec.ts",
    "test:e2e:report": "playwright show-report",
    "test:mobile": "wdio run appium.config.ts",
    "test:mobile:ios": "MOBILE_PLATFORM=ios wdio run appium.config.ts",
    "test:mobile:android": "MOBILE_PLATFORM=android wdio run appium.config.ts",
    "test:browserstack": "wdio run browserstack.config.ts",
    "test:browserstack:ios": "MOBILE_PLATFORM=ios wdio run browserstack.config.ts",
    "test:browserstack:android": "MOBILE_PLATFORM=android wdio run browserstack.config.ts",
    "test:a11y": "vp test run --reporter=verbose a11y",
    "test:e2e:a11y": "playwright test e2e/accessibility.spec.ts",
    "test:all": "yarn test:unit && yarn test:e2e",
    "lint": "vp check",
    "lint:fix": "vp check --fix",
    "format": "vp fmt",
    "clean": "rm -rf dist .vite playwright-report test-results allure-results screenshots appium-logs",
    "deploy:dev": "wrangler deploy --env development",
    "deploy:prod": "wrangler deploy --env production",
    "pwa-screenshots:deploy:dev": "cd scripts/pwa-screenshots && yarn install && wrangler deploy --env development",
    "pwa-screenshots:deploy:prod": "cd scripts/pwa-screenshots && yarn install && wrangler deploy --env production",
    "pwa-screenshots:generate:dev": "curl -s https://happy-pwa-screenshots-dev.enflamemedia.workers.dev/generate",
    "pwa-screenshots:generate:prod": "curl -s https://happy-pwa-screenshots.enflamemedia.workers.dev/generate",
    "pwa-screenshots:download:dev": "cd scripts/pwa-screenshots && ./download-screenshots.sh dev",
    "pwa-screenshots:download:prod": "cd scripts/pwa-screenshots && ./download-screenshots.sh prod",
    "pwa-screenshots:status:dev": "curl -s https://happy-pwa-screenshots-dev.enflamemedia.workers.dev/status",
    "pwa-screenshots:status:prod": "curl -s https://happy-pwa-screenshots.enflamemedia.workers.dev/status"
  },
  "dependencies": {
    "@11labs/client": "^0.2.0",
    "@magic-agent/protocol": "workspace:*",
    "@revenuecat/purchases-js": "^1.33.0",
    "@rive-app/webgl2": "^2.37.1",
    "@tabler/icons-vue": "^3.41.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/vue-form": "^1.29.0",
    "@tanstack/vue-table": "^8.21.3",
    "@unovis/ts": "^1.6.4",
    "@unovis/vue": "^1.6.4",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/node-toolbar": "^1.1.1",
    "@vueuse/core": "^14.2.1",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "ai": "^6.0.162",
    "ansi-to-vue3": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "4.4.2",
    "embla-carousel-vue": "^8.6.0",
    "jszip": "^3.10.1",
    "lucide-vue-next": "^1.0.0",
    "media-chrome": "^4.19.0",
    "motion-v": "^2.2.1",
    "nanoid": "^5.1.9",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.6",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tokenlens": "^1.3.1",
    "tweetnacl": "^1.0.3",
    "vue": "^3.5.32",
    "vue-i18n": "^11.3.2",
    "vue-input-otp": "^0.3.2",
    "vue-router": "^5.0.4",
    "vue-sonner": "^2.0.9",
    "vue-stick-to-bottom": "^1.0.0",
    "vue-stream-markdown": "^0.7.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@cloudflare/vite-plugin": "^1.32.2",
    "@percy/cli": "^1.31.11",
    "@percy/playwright": "^1.1.0",
    "@playwright/test": "^1.59.1",
    "@types/jszip": "^3.4.1",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "@wdio/allure-reporter": "^9.27.0",
    "@wdio/appium-service": "^9.27.0",
    "@wdio/browserstack-service": "^9.27.0",
    "@wdio/cli": "^9.27.0",
    "@wdio/junit-reporter": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "@wdio/types": "^9.27.0",
    "happy-dom": "^20.9.0",
    "shadcn-vue": "^2.6.2",
    "ts-node": "^10.9.2",
    "turbo": "^2.9.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plus": "^0.1.18",
    "vitest": "^4.1.4",
    "vitest-axe": "^0.1.0",
    "vue-tsc": "^3.2.6",
    "wrangler": "^4.82.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "happy",
    "vue",
    "monorepo",
    "claude-code"
  ],
  "license": "MIT"
}
